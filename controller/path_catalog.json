{
  "profiles": {
    "fec_only": {
      "description": "Collect FEC-related telemetry from native interface-root state telemetry",
      "paths": [
        "/state/interfaces/interface[name={interface}]/"
      ]
    },
    "optics_only": {
      "description": "Collect Junos native optics telemetry",
      "paths": [
        "/junos/system/linecard/optics/"
      ]
    },
    "qmon_only": {
