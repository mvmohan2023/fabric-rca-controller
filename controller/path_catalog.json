        "/interfaces/interface[name={interface}]/state/counters/in-octets",
        "/interfaces/interface[name={interface}]/state/counters/out-octets",
        "/interfaces/interface[name={interface}]/state/counters/in-errors",
        "/junos/system/linecard/optics/"
      ]
