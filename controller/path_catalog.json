    "full_interface_health": {
      "description": "Collect supported OpenConfig interface counters with native interface-root state, qmon, and optics telemetry for health validation",
      "paths": [
        "/interfaces/interface[name={interface}]/state/oper-status",
        "/interfaces/interface[name={interface}]/state/counters/carrier-transitions",
        "/interfaces/interface[name={interface}]/state/counters/in-octets",
